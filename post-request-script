const statusCodes = {
    200: "✅ Успешно",
    201: "✅ Ресурс создан",
    202: "✅ Принято",
    204: "🛑 Нет содержимого",
    400: "🚫 Неверный запрос",
    401: "🚷 Неавторизован",
    403: "⛔ Доступ запрещён",
