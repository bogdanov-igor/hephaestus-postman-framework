// ╔════════════════════════════════════════════════════════════════════════════╗
// ║ 🔍 Универсальное извлечение массива из вложенных структур                  ║
// ╚════════════════════════════════════════════════════════════════════════════╝
const deepExtractArray = (data, path) => {
    if (!path || path === "") {
        return Array.isArray(data)
            ? data
            : [data]; // 👈 не трогаем объекты!
    }
    const segments = path
        .replace(/\[(\d+)\]/g, '.$1')
        .replace(/\[\*\]|\[\]/g, '.*')
        .split('.')
        .filter(p => p.length);
    const traverse = (target, idx) => {
        if (idx === segments.length) {
            return Array.isArray(target)
                ? target
                : [target]; // 👈 безопасно возвращаем всё как массив
        }
        const key = segments[idx];
        if (key === '*') {
            if (!Array.isArray(target)) return [];
            return target.flatMap(item => traverse(item, idx + 1));
        } else {
            if (target === undefined || target === null) return [];
            return traverse(target[key], idx + 1);
        }
    };
    return traverse(data, 0);
};
