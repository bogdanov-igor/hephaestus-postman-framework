// ╔════════════════════════════ 📊 ПОДСЧЁТ ЭЛЕМЕНТОВ ═══════════════════════════╗
// ║ Анализ по `keysToCount` с поддержкой `type`:                              ║
// ║ — type: "array"  → ожидается массив, считается `.length`                 ║
// ║ — type: "object" → ожидается объект, считается `Object.keys().length`   ║
// ║ Если `type` не указан — поведение по умолчанию: ожидается массив.       ║
// ╚═══════════════════════════════════════════════════════════════════════════╝
    Object.entries(keysToCount).forEach(([alias, options]) => {
        let {
            path,
            expected,
            filter,
            transformBefore,
            transformAfter,
            ignoreCase,
            type = "array" // 🧠 По умолчанию: массив
        } = options;
        let extracted = deepExtractArray(source, path);
        // 💠 Преобразование объекта в массив записей, если type: "object"
        if (type === "object") {
            if (
                extracted &&
                typeof extracted === "object" &&
                !Array.isArray(extracted)
            ) {
                extracted = Object.entries(extracted); // ✅ Преобразуем в массив пар
            } else if (Array.isArray(extracted) && extracted.length === 1 && typeof extracted[0] === "object" && !Array.isArray(extracted[0])) {
                // 🧠 Иногда deepExtractArray оборачивает объект в массив — исправляем
                extracted = Object.entries(extracted[0]);
            } else {
                console.warn(`⚠️ '${alias}': ожидался объект, но получено:`, extracted);
