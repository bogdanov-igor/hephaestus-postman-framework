// ╔════════════════════════════════════════════════════════════════════════════╗
// ║ 🔧 Рекурсивное приведение всех строк к нижнему регистру                    ║
// ╚════════════════════════════════════════════════════════════════════════════╝
const toLowerDeep = obj => {
    if (typeof obj === 'string') return obj.toLowerCase();
    if (Array.isArray(obj)) return obj.map(toLowerDeep);
    if (typeof obj === 'object' && obj !== null) {
        return Object.fromEntries(Object.entries(obj).map(([k, v]) => [k, toLowerDeep(v)]));
    }
    return obj;
};
// ╔════════════════════════════════════════════════════════════════════════════╗
// ║ 🧬 Получение значения по пути: аналог _.get                                ║
// ╚════════════════════════════════════════════════════════════════════════════╝
// const getDeep = (obj, path) => path.split('.').reduce((acc, part) => acc && acc[part], obj);
const getDeep = (obj, path) => {
    if (!path) return undefined;
    const parts = path
        .replace(/\[(\d+)\]/g, '.$1')    // [0] → .0
        .replace(/\[\*\]|\[\]/g, '.*')   // [*] / [] → .*
        .split('.')
        .filter(p => p.length);          // <== Удаляем пустые сегменты
    const traverse = (target, idx) => {
        if (idx === parts.length) return target;
        const key = parts[idx];
        if (key === '*') {
            if (!Array.isArray(target)) return [];
            return target.flatMap(item => {
                const result = traverse(item, idx + 1);
                return result === undefined ? [] : result;
            });
        } else {
            if (target === undefined || target === null) return undefined;
            return traverse(target[key], idx + 1);
        }
    };
    return traverse(obj, 0);
};
