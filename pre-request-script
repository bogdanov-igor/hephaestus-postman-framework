// ║ 📅 ФУНКЦИЯ: Форматирование даты в формате yyyy-mm-dd                       ║
// ╚════════════════════════════════════════════════════════════════════════════╝
function shiftDateMonths(date, months) {
    const newDate = new Date(date);
    const d = newDate.getDate();
    newDate.setDate(1);
    newDate.setMonth(newDate.getMonth() - months);
    const lastDay = new Date(newDate.getFullYear(), newDate.getMonth() + 1, 0).getDate();
    newDate.setDate(Math.min(d, lastDay));
    return newDate;
}
function formatDateFn(date, formatStr = "yyyy-MM-dd") {
    const pad = (v, len = 2) => String(v).padStart(len, '0');
    const replacements = {
        yyyy: date.getFullYear(),
        MM: pad(date.getMonth() + 1),
        dd: pad(date.getDate()),
        hh: pad(date.getHours()),
        mm: pad(date.getMinutes()),
        ss: pad(date.getSeconds()),
        nnn: pad(date.getMilliseconds(), 3),
        tt00: (() => {
            const offset = -date.getTimezoneOffset();
            const sign = offset >= 0 ? "+" : "-";
            const abs = Math.abs(offset);
            return `${sign}${pad(Math.floor(abs / 60))}${pad(abs % 60)}`;
        })()
    };
    return Object.entries(replacements).reduce(
        (str, [token, val]) => str.replaceAll(token, val),
        formatStr
    );
}
