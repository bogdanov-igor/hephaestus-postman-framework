function interpolate(template) {
    return template.replace(/{{(.*?)}}/g, (_, key) => {
        return (
            pm.variables.get(key) ||
            pm.environment.get(key) ||
            pm.collectionVariables.get(key) ||
            ''
        );
    });
}
