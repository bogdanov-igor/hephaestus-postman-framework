// ║ 🛠️  Функция ручной интерполяции переменных в виде {{var}}                  ║
// ╚════════════════════════════════════════════════════════════════════════════╝
function interpolate(str) {
    return str.replace(/{{(\w[\w\-]*)}}/g, (_, varName) => {
        const value = pm.environment.get(varName) || pm.globals.get(varName);
        if (value === undefined) {
            throw new Error(`🚫 Переменная окружения ${varName} не найдена`);
        }
        return value;
    });
}
