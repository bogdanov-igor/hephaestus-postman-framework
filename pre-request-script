// ║ 🔍 Основной блок: формирование URL и проверка доступности                  ║
// ╚════════════════════════════════════════════════════════════════════════════╝
pm.test("🔍 Проверка подготовки запроса", function () {
    let url = "";
    try {
        // Получаем шаблон baseUrl из коллекции и интерполируем.
        let baseUrlKey = `${environment}.url.${zone}`;
        let baseUrlTemplate = pm.collectionVariables.get(baseUrlKey);
        pm.expect(baseUrlTemplate, `🚫 ${baseUrlKey} должен быть установлен`).to.not.be.undefined;
        let baseUrl = interpolate(baseUrlTemplate);
        pm.expect(baseUrl, "🚫 baseUrl после интерполяции должен быть валидным").to.be.a("string").and.to.have.length.greaterThan(0);
        // Получаем endpoint из коллекции и интерполируем.
        const endpointTemplate = pm.collectionVariables.get(`${environment}.prefix.${methodType}`);
        pm.expect(endpointTemplate, `🚫 ${methodType} должен быть определен в переменных коллекции`).to.not.be.undefined;
        const endpoint = interpolate(endpointTemplate);
        url = baseUrl + endpoint;
        pm.test("✅ Формирование URL", function () {
            pm.expect(url, "URL должен быть корректной строкой").to.be.a("string").and.to.have.length.greaterThan(0);
            pm.expect(url, "🚫 Некорректный формат URL").to.match(/^https?:\/\/[^\s/$.?#].[^\s]*$/);
        });
        // ╔════════════════════════════════════════════════════════════════════════════╗
        // ║ 📡 ПИНГ: Проверка доступности сервера                                      ║
        // ╚════════════════════════════════════════════════════════════════════════════╝
        pm.test("📡 Проверка доступности сервера", function () {
            pm.sendRequest({
                url: baseUrl,
                method: 'GET'
            }, (err, res) => {
                if (err) {
                    throw new Error(`🚫 Ошибка пинга: ${err.message}`);
                }
                pm.expect(res, `✅ Получен ответ от ${baseUrl}`).to.exist;
                pm.expect(true, `📡 Пинг ${baseUrl} завершен со статусом ${res.code} 🚀`).to.be.true;
            });
        });
    } catch (error) {
        pm.test("🚫 Ошибка формирования URL", function () {
            throw new Error(`🚫 Ошибка: ${error.message}`);
        });
    }
    
    // ╔════════════════════════════════════════════════════════════════════╗
    // ║ 👤 Обработка пользователя (авторизация или user.technical.main)    ║
    // ╚════════════════════════════════════════════════════════════════════╝
    if (isAuthMethod || getUser === "user.technical.main") {
        try {
            const userDataTemplate = pm.collectionVariables.get(getUser);
            pm.expect(userDataTemplate, `🚫 Переменная ${getUser} должна быть установлена`).to.not.be.undefined;
            const userData = interpolate(userDataTemplate);
            const parts = userData.split("|");
            if (getUser === "user.technical.main") {
                pm.expect(parts.length, "🚫 user.technical.main должен содержать login|channel|password").to.equal(3);
                const [login, channel, password] = parts;
                pm.expect(login, "🚫 Логин должен быть указан").to.not.be.empty;
                pm.expect(channel, "🚫 Канал должен быть указан").to.not.be.empty;
                pm.expect(password, "🚫 Пароль должен быть указан").to.not.be.empty;
                pm.variables.set("pmv-login", login);
                pm.variables.set("pmv-channel", channel);
                pm.variables.set("pmv-password", password);
            } else {
                pm.expect(parts.length, "🚫 Данные пользователя должны содержать login|password").to.equal(2);
                const [login, password] = parts;
                pm.expect(login, "🚫 Логин должен быть указан").to.not.be.empty;
                pm.expect(password, "🚫 Пароль должен быть указан").to.not.be.empty;
                pm.variables.set("pmv-login", login);
                pm.variables.set("pmv-password", password);
            }
            // Устанавливаем переменные (общие)
            pm.variables.set("pmv-url", url);
            pm.variables.set("pmv-request", responseType);
            const summary = [
                `🔹 Метод: ${pm.request.method}`,
                `🔹 Тип: ${methodType.toUpperCase()}`,
                `🔹 URL: ${url}/`,
                `🔹 Ожидаемый ответ: ${responseType.toUpperCase()}`,
                `🔹 Пользователь: ${pm.variables.get("pmv-login").toUpperCase()}`
            ].join(" |");
            const timestamp = new Date().toISOString();
            pm.test("📋 Конфигурация запроса: " + summary, function () {
                pm.expect(true).to.be.true;
                console.log(`📋 Итоговый отчет от ${timestamp.split("T").join(" ")}:\n` + summary.replace(/ \|/g, "\n"));
            });
        } catch (error) {
            pm.test("🚫 Ошибка проверки пользовательских данных", function () {
                throw new Error(`🚫 Ошибка: ${error.message}`);
            });
        }
    } else {
        // Без авторизации и без user.technical.main — устанавливаем только URL и тип ответа
        pm.variables.set("pmv-url", url);
        pm.variables.set("pmv-request", responseType);
        console.log("🔓 Метод не требует авторизации: пользователь не обрабатывается.");
    }
});
