// ║ 📅 УСТАНОВКА СТАНДАРТНЫХ ДАТ В ПЕРЕМЕННЫЕ                                  ║
// ╚════════════════════════════════════════════════════════════════════════════╝
(function setStandardDates() {
    const currentDate = new Date();
    const dates = {
        current: new Date(currentDate),
        monthsAgo1: shiftDateMonths(currentDate, 1),
        monthsAgo3: shiftDateMonths(currentDate, 3),
        monthsAgo6: shiftDateMonths(currentDate, 6),
        monthsAgo12: shiftDateMonths(currentDate, 12)
    };
    const formattedDates = {
        currentDate: formatDateFn(dates.current, dateFormat),
        monthsAgo1: formatDateFn(dates.monthsAgo1, dateFormat),
        monthsAgo3: formatDateFn(dates.monthsAgo3, dateFormat),
        monthsAgo6: formatDateFn(dates.monthsAgo6, dateFormat),
        monthsAgo12: formatDateFn(dates.monthsAgo12, dateFormat)
    };
    Object.entries(formattedDates).forEach(([key, value]) => {
        pm.variables.set(key, value);
    });
    console.log("📆 Установлены переменные дат:", formattedDates);
})();
